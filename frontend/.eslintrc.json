{
  "root": true,
  "env": {
    "browser": true,
    "es2022": true,
    "node": true
  },
  "extends": [
    "eslint:recommended"
  ],
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module",
    "ecmaFeatures": {
      "jsx": true
    }
  },
  "plugins": [
    "@typescript-eslint",
    "react-hooks",
    "react-refresh"
  ],
  "settings": {
    "react": {
      "version": "18"
    }
  },
  "globals": {
    "React": "readonly",
    "JSX": "readonly",
    "NodeJS": "readonly",
    "RequestInit": "readonly"
  },
  "rules": {
    "no-unused-vars": "off",
    "@typescript-eslint/no-unused-vars": ["warn", { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_" }],
    "no-empty": ["warn", { "allowEmptyCatch": true }],
    "no-console": "off",
    "no-useless-escape": "warn",
    "react-hooks/rules-of-hooks": "error",
    "react-hooks/exhaustive-deps": "warn",
    "react-refresh/only-export-components": ["warn", { "allowConstantExport": true }]
  },
  "ignorePatterns": [
    "dist",
    "node_modules",
    "src/types/bridge-types.ts",
    "*.config.js",
    "*.config.ts",
    "vite.config.ts"
  ]
}
